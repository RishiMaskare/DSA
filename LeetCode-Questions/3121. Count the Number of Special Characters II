class Solution {
public:
    int numberOfSpecialChars(string word) {
        int n = word.size();
        unordered_map<char, int> lastLower, firstUpper;
        for(int i=0;i<n;i++) {
            char ch = word[i];
            if(islower(ch)) {
                lastLower[ch] = i;
            } else {
                // store only the first occurence of uppercase character
                if(firstUpper.find(ch) == firstUpper.end()) {
                    // not found 
                    firstUpper[ch] = i;
                }
            }
        }
        int ans = 0;
        for(int i=0;i<n;i++) {
            char ch = word[i];
            if(isupper(ch)) {
                char lower = tolower(word[i]);
                char upper = toupper(word[i]);
                if(lastLower.find(lower) != lastLower.end()) {
                    if(lastLower[lower] < firstUpper[upper]) {
                        ans++;
                        lastLower.erase(lower);
                    }
                }
            }
        }
        return ans;
    }
};
