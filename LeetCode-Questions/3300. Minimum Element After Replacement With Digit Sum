class Solution {
public:
    int minElement(vector<int>& nums) {
        int ans = INT_MAX;
        for(int num : nums) {
            int sumDigit = 0;
            while(num > 0) {
                sumDigit += num % 10;
                num /= 10; 
            }
            ans = min(ans, sumDigit);
        }
        return ans;
    }
};
